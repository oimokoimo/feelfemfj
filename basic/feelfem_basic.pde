/* FEEL-LIB 直接数値積分法 rec2a[rect]      */
/*------------------------------------------*/  
quadrature rec2a[rect] {
    double px0 = sqrt(2.0/3.0);
    double py0 = 0;
    double px1 = -1.0/sqrt(6.0);
    double py1 =  1.0/sqrt(2.0);

    (px0,py0): 4.0/3.0;
    (px1,py1): 4.0/3.0;
    (px1,-py1): 4.0/3.0;
}

