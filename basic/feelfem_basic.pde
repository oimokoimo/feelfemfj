
/* 基底関数 */

quadrature tet2[tetra] {   /* quadratic order */
  double a,b;

  a = (5.0-sqrt(5.0))/20.0;
  b = (5.0+3.0*sqrt(5.0))/20.0;

  (a,a,a) : 1.0 / 24.0;
  (a,a,b) : 1.0 / 24.0;
  (a,b,a) : 1.0 / 24.0;
  (b,a,a) : 1.0 / 24.0;
}

quadrature tet3[tetra] {   /* Cubic order */
  double p2,p4,p6;
  double w,wm;

  p2 =  1.0 / 2.0;
  p4 =  1.0 / 4.0;
  p6 =  1.0 / 6.0;

  w  =  9.0 / 20.0 / 6.0;
  wm = -4.0 /  5.0 / 6.0;

  (p4,p4,p4) : wm;
  (p2,p6,p6) : w;
  (p6,p2,p6) : w;
  (p6,p6,p2) : w;
  (p6,p6,p6) : w;
}

/* 3D tetrahedra elements */

element T1[tetra] {
  (0,0,0): 1.0-r-s-t;
  (1,0,0): r;
  (0,1,0): s;
  (0,0,1): t;
}

element T2[tetra] {
  (0,0,0): (1.0-r-t-s)*(2.0*(1.0-r-t-s) - 1.0);
  (1,0,0): r *(2.0*r - 1.0);
  (0,1,0): s *(2.0*s - 1.0);
  (0,0,1): t *(2.0*t - 1.0);
  (0.5,0,0) : 4.0*r*(1.0-r-t-s);
  (0.5,0.5,0) : 4.0 * r * s ;
  (0,0.5,0) : 4.0 * s * (1.0-r-t-s);
  (0,0,0.5) : 4.0 * t * (1.0-r-t-s);
  (0.5,0,0.5): 4.0 * r * t;
  (0,0.5,0.5): 4.0 * s * t;
}


/*-----------------------------------*/
/* FEEL-LIB 三角形一次要素  P1[tri]  */
/*-----------------------------------*/
element P1[tri] {
  (0,0): 1.0-r-s;
  (1,0): r;
  (0,1): s;
}

/*-----------------------------------*/
/* FEEL-LIB 三角形二次要素  P2[tri]  */
/*-----------------------------------*/
element P2[tri] {
  (0  ,0  ): 1.0 - 3.0 * r + 2.0 * r *r - 3.0 * s + 4.0*r * s + 2.0 * s * s;
  (1/2,0  ): 4.0*r - 4.0 * r * r - 4.0 * r * s;
  (1  ,0  ): 2.0*r*r - r;
  (1/2,1/2): 4.0 * r * s;
  (0  ,1  ): 2.0*s * s - s;
  (0  ,1/2): 4.0*s - 4.0*r*s - 4.0*s*s;
}


/*-------------------------------------*/
/* FEEL-LIB 四辺形双一次要素  Q1[rect] */
/*-------------------------------------*/
element Q1[rect] {
   (-1,-1): (1.0-r)*(1.0-s) * 0.25 ;
   ( 1,-1): (1.0+r)*(1.0-s) * 0.25 ;
   ( 1, 1): (1.0+r)*(1.0+s) * 0.25 ;
   (-1, 1): (1.0-r)*(1.0+s) * 0.25 ;
}


/*-----------------------------------------*/
/* FEEL-LIB Serenpidity ２次要素  Q2[rect] */
/*-----------------------------------------*/
element Q2[rect] {
   (-1,-1):  (r- 1.0)*(1.0-s)*(1.0+s+r)*0.25;
   ( 0,-1):  (1.0-r*r)*(1.0-s)*0.5;
   ( 1,-1):  (-1.0-r)*(1.0-s)*(1.0-r+s)*0.25;
   ( 1, 0):  (1.0+r)*(1.0-s * s)*0.5;
   ( 1, 1): -(1.0+r)*(1.0+s)*(1.0-s-r)*0.25;
   ( 0, 1):  (1.0- r*r)*(1.0+s)*0.5;
   (-1, 1):  (r- 1.0)*(1.0+s)*(1.0+r-s)*0.25;
   (-1, 0):  (1.0-r)*(1.0- s*s)*0.5;
}


/* Serenpidity ３次要素 */
 /* 疲れたからやんぴ */

/*---------------------------------------*/
/* FEEL-LIB 完全四辺形２次要素 Q2A[rect] */
/*---------------------------------------*/
element Q2A[rect] {
   (-1,-1):  (1.0-r)*(1.0-s)*r*s*0.25;
   ( 0,-1): -(1.0-r*r)*(1.0-s)*s*0.5;
   ( 1,-1): -(1.0+r)*(1.0-s)*r*s*0.25;
   ( 1, 0):  (1.0+r)*(1.0-s*s)*r *0.5 ;
   ( 1, 1):  (1.0+r)*(1.0+s)*r*s*0.25;
   ( 0, 1):  (1.0-r*r)*(1.0+s)*s*0.5;
   (-1, 1):  -(1.0-r)*(1.0+s)*r*s*0.25;
   (-1, 0): -(1.0-r)*(1.0-s*s)*r*0.5;
   ( 0, 0):  (1.0-r*r)*(1.0-s*s);
}

quadrature gauss2x2[rect] {
    double p =  0.577350269189626;
    double pm= -0.577350269189626;
   ( p, p): 1;
   ( p,pm): 1;
   (pm, p): 1;
   (pm,pm): 1;
}



quadrature gauss3x3[rect] {
    double p =  sqrt(3.0/5.0);
    double w1 = 8.0/9.0;
    double w2 = 5.0/9.0;

    (0,p) : w1 * w2;
    (0,-p): w1 * w2;
    (0,0) : w1 * w1;
    (p,p) : w2 * w2;
    (p,0) : w2 * w1;
    (p,-p): w2 * w2;
    (-p,-p): w2 * w2;
    (-p,0) : w2 * w1;
    (-p,p) : w2 * w2;
}

quadrature gauss3[line] {
    double p =  sqrt(3.0/5.0);
    double w1 = 8.0/9.0;
    double w2 = 5.0/9.0;

    (-p ) : w2;
    ( 0 ) : w1;
    ( p ) : w2;
}
